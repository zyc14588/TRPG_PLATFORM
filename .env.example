# Local development defaults. Copy this file to .env and set local passwords.
TRPG_AUTH_MODE=development
TRPG_AUTH_SECRET=development-secret-at-least-32-bytes-change-me
TRPG_ALLOW_IN_MEMORY_STORE=false
DATABASE_URL=postgres://trpg_app:<password>@localhost:5432/trpg_platform
POSTGRES_PASSWORD=<set-postgres-password>
REDIS_URL=redis://localhost:6379
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=trpg-platform
MINIO_ROOT_USER=<set-minio-root-user>
MINIO_ROOT_PASSWORD=<set-minio-root-password>
OBJECT_STORAGE_ACCESS_KEY=<set-minio-root-user>
OBJECT_STORAGE_SECRET_KEY=<set-minio-root-password>
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<set-grafana-admin-password>

OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080/v1

TRPG_CONFIG_PATH=config/default.toml
TRPG_BIND_ADDR=127.0.0.1:8080
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# Production example:
# - Never use the postgres superuser as the application login role.
# - Use a unique TRPG_AUTH_SECRET with at least 32 bytes.
# - Set TRPG_AUTH_MODE=production explicitly.
# TRPG_AUTH_MODE=production
# TRPG_AUTH_SECRET=<unique-production-secret-at-least-32-bytes>
# DATABASE_URL=postgres://trpg_app:<password>@db.example:5432/trpg_platform
