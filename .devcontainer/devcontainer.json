{
  "name": "TRPG Platform",
  "dockerComposeFile": "../infra/compose/compose.yaml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "cargo install sqlx-cli --version 0.9.0 --no-default-features --features native-tls,postgres --locked",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
