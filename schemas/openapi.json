{
  "openapi": "3.1.0",
  "info": {
    "title": "TRPG Platform API",
    "version": "0.1.0",
    "description": "TRPG Platform system, auth, and room REST API contract."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080"
    }
  ],
  "tags": [
    {
      "name": "system"
    },
    {
      "name": "auth"
    },
    {
      "name": "rooms"
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "tags": ["system"],
        "operationId": "healthz",
        "responses": {
          "200": {
            "description": "Liveness status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/readyz": {
      "get": {
        "tags": ["system"],
        "operationId": "readyz",
        "responses": {
          "200": {
            "description": "Readiness status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service is not ready; response omits secrets and raw internal errors.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyResponse"
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": ["system"],
        "operationId": "metrics",
        "responses": {
          "200": {
            "description": "Prometheus metrics.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "tags": ["system"],
        "operationId": "openapiJson",
        "responses": {
          "200": {
            "description": "This OpenAPI document.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/magic-link/request": {
      "post": {
        "tags": ["auth"],
        "operationId": "requestMagicLink",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MagicLinkRequestBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Magic Link challenge created. Development mode may include a link; production never returns the token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MagicLinkRequestResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/auth/magic-link/verify": {
      "post": {
        "tags": ["auth"],
        "operationId": "verifyMagicLink",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MagicLinkVerifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated session. Also sets refresh and CSRF cookies.",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSessionResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/auth/oidc/{provider}/start": {
      "get": {
        "tags": ["auth"],
        "operationId": "startOidcLogin",
        "parameters": [
          {
            "$ref": "#/components/parameters/Provider"
          }
        ],
        "responses": {
          "200": {
            "description": "Development OIDC authorization URL.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OidcStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/auth/oidc/{provider}/callback": {
      "get": {
        "tags": ["auth"],
        "operationId": "completeOidcLogin",
        "parameters": [
          {
            "$ref": "#/components/parameters/Provider"
          },
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Authenticated session. Also sets refresh and CSRF cookies.",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSessionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": ["auth"],
        "operationId": "refreshSession",
        "security": [
          {
            "RefreshSessionCookie": [],
            "CsrfToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Rotated refresh session and new access token.",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSessionResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["auth"],
        "operationId": "logout",
        "security": [
          {
            "RefreshSessionCookie": [],
            "CsrfToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current refresh session revoked.",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogoutResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "tags": ["auth"],
        "operationId": "getMe",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/rooms": {
      "get": {
        "tags": ["rooms"],
        "operationId": "listRooms",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Rooms visible to the current user.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListRoomsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "tags": ["rooms"],
        "operationId": "createRoom",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoomRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created room or idempotent replay.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoomResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/api/rooms/{room_id}": {
      "get": {
        "tags": ["rooms"],
        "operationId": "getRoom",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RoomId"
          }
        ],
        "responses": {
          "200": {
            "description": "Role-safe room projection.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoomResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/rooms/{room_id}/invitations": {
      "post": {
        "tags": ["rooms"],
        "operationId": "createRoomInvitation",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RoomId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvitationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "One-time room invitation token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateInvitationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/api/room-invitations/{token}/accept": {
      "post": {
        "tags": ["rooms"],
        "operationId": "acceptRoomInvitation",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptInvitationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Accepted invitation and joined room projection.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoomResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/api/rooms/{room_id}/members": {
      "get": {
        "tags": ["rooms"],
        "operationId": "listRoomMembers",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RoomId"
          }
        ],
        "responses": {
          "200": {
            "description": "Room members visible to a room member.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListRoomMembersResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      },
      "RefreshSessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "trpg_refresh"
      },
      "CsrfToken": {
        "type": "apiKey",
        "in": "header",
        "name": "x-csrf-token"
      }
    },
    "parameters": {
      "Provider": {
        "name": "provider",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "RoomId": {
        "name": "room_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorBody"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required or invalid.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorBody"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Request rejected by authorization or CSRF policy.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorBody"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found. Private room existence is not distinguished from non-membership.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorBody"
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflict, including idempotency-key mismatch.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorBody"
            }
          }
        }
      }
    },
    "schemas": {
      "AcceptInvitationRequest": {
        "type": "object",
        "required": ["idempotency_key"],
        "properties": {
          "idempotency_key": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "AuthSessionResponse": {
        "type": "object",
        "required": [
          "access_token",
          "token_type",
          "access_token_expires_at_unix",
          "csrf_token",
          "user"
        ],
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "const": "Bearer"
          },
          "access_token_expires_at_unix": {
            "type": "integer",
            "minimum": 0
          },
          "csrf_token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserDto"
          }
        },
        "additionalProperties": false
      },
      "CreateInvitationRequest": {
        "type": "object",
        "required": ["email", "role", "idempotency_key"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "$ref": "#/components/schemas/InvitationRole"
          },
          "idempotency_key": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "CreateInvitationResponse": {
        "type": "object",
        "required": [
          "room_id",
          "invited_email",
          "role",
          "expires_at_unix",
          "token",
          "invitation_url"
        ],
        "properties": {
          "room_id": {
            "type": "string",
            "format": "uuid"
          },
          "invited_email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "$ref": "#/components/schemas/RoomRole"
          },
          "expires_at_unix": {
            "type": "integer",
            "minimum": 0
          },
          "token": {
            "type": "string"
          },
          "invitation_url": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateRoomRequest": {
        "type": "object",
        "required": ["title", "system_name", "privacy_mode", "idempotency_key"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "system_name": {
            "type": "string",
            "minLength": 1
          },
          "privacy_mode": {
            "$ref": "#/components/schemas/RoomPrivacyMode"
          },
          "idempotency_key": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "ErrorBody": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "HealthResponse": {
        "type": "object",
        "required": ["status", "service", "decision_baseline", "region_id"],
        "properties": {
          "status": {
            "type": "string"
          },
          "service": {
            "type": "string"
          },
          "decision_baseline": {
            "type": "string"
          },
          "region_id": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "InvitationRole": {
        "type": "string",
        "enum": ["kp", "assistant_kp", "pl", "observer", "public_screen"]
      },
      "ListRoomMembersResponse": {
        "type": "object",
        "required": ["members"],
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoomMemberDto"
            }
          }
        },
        "additionalProperties": false
      },
      "ListRoomsResponse": {
        "type": "object",
        "required": ["rooms"],
        "properties": {
          "rooms": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoomDto"
            }
          }
        },
        "additionalProperties": false
      },
      "LogoutResponse": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "const": "logged_out"
          }
        },
        "additionalProperties": false
      },
      "MagicLinkRequestBody": {
        "type": "object",
        "required": ["email", "redirect_uri"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "redirect_uri": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "MagicLinkRequestResponse": {
        "type": "object",
        "required": [
          "status",
          "challenge_id",
          "expires_at_unix",
          "development_magic_link"
        ],
        "properties": {
          "status": {
            "type": "string",
            "const": "sent"
          },
          "challenge_id": {
            "type": "string",
            "format": "uuid"
          },
          "expires_at_unix": {
            "type": "integer",
            "minimum": 0
          },
          "development_magic_link": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      },
      "MagicLinkVerifyRequest": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "MeResponse": {
        "type": "object",
        "required": ["user"],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserDto"
          }
        },
        "additionalProperties": false
      },
      "OidcStartResponse": {
        "type": "object",
        "required": ["provider", "authorization_url", "state"],
        "properties": {
          "provider": {
            "type": "string"
          },
          "authorization_url": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ReadyResponse": {
        "type": "object",
        "required": ["status", "checks"],
        "properties": {
          "status": {
            "type": "string"
          },
          "checks": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "RoomDto": {
        "type": "object",
        "required": [
          "id",
          "title",
          "system_name",
          "privacy_mode",
          "version",
          "my_role"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "system_name": {
            "type": "string"
          },
          "privacy_mode": {
            "$ref": "#/components/schemas/RoomPrivacyMode"
          },
          "version": {
            "type": "integer"
          },
          "my_role": {
            "$ref": "#/components/schemas/RoomRole"
          }
        },
        "additionalProperties": false
      },
      "RoomMemberDto": {
        "type": "object",
        "required": ["user_id", "role"],
        "properties": {
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "$ref": "#/components/schemas/RoomRole"
          }
        },
        "additionalProperties": false
      },
      "RoomPrivacyMode": {
        "type": "string",
        "enum": ["standard", "private_hybrid", "local_only"]
      },
      "RoomResponse": {
        "type": "object",
        "required": ["room"],
        "properties": {
          "room": {
            "$ref": "#/components/schemas/RoomDto"
          }
        },
        "additionalProperties": false
      },
      "RoomRole": {
        "type": "string",
        "enum": ["owner", "kp", "assistant_kp", "pl", "observer", "public_screen"]
      },
      "UserDto": {
        "type": "object",
        "required": ["id", "email", "display_name"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "display_name": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
